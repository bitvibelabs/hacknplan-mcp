# hacknplan-mcp configuration — copy to `.env` and fill in, or export these in your shell.
# The server reads credentials ONLY from the environment; nothing is written to disk.

# Required: your HacknPlan API key.
# Create one at HacknPlan -> avatar -> Settings -> API -> Create (tick the scopes you need).
HACKNPLAN_API_KEY=

# Optional: only needed for the Trello -> HacknPlan migration tools.
# Get both at https://trello.com/power-ups/admin
TRELLO_API_KEY=
TRELLO_TOKEN=

# Optional: group projects for the portfolio / dashboard views (HacknPlan has no
# "workspace" tier). JSON object mapping a group label to a list of project names.
# If unset, every project falls under a single "All Projects" group.
# Example:
# HACKNPLAN_GROUPS={"Products":["Website","Mobile App"],"Ops":["Infra","Support"]}
HACKNPLAN_GROUPS=
